# Flask environment: development | production | testing
FLASK_ENV=development

# Secret key — CHANGE THIS in production!
SECRET_KEY=dev-secret-change-in-production

# Database URL
# SQLite (development):
DATABASE_URL=sqlite:///humanwrite.db
# PostgreSQL (production — uncomment and configure):
# DATABASE_URL=postgresql://user:password@localhost:5432/humanwriteai

# Logging
LOG_LEVEL=INFO